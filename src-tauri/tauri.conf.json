{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "aqua",
  "version": "0.1.0",
  "identifier": "com.aqua.app",
  "build": {
    "frontendDist": "../app/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm build:connector:if-missing && pnpm --filter @aqua/app dev",
    "beforeBuildCommand": "pnpm build:connector && pnpm --filter @aqua/app build"
  },
  "app": {
    "windows": [
      {
        "title": "aqua",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/builtin-biztypes.json", "resources/connector.jar"]
  }
}
